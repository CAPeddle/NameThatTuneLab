# EditorConfig — Android App Template
# https://editorconfig.org
# ktlint uses these settings for formatting rules

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 120

[*.kt]
indent_size = 4
max_line_length = 120
# ktlint specific
ktlint_code_style = android_studio
ktlint_function_naming_ignore_when_annotated_with = Composable

[*.kts]
indent_size = 4
max_line_length = 120

[*.xml]
indent_size = 4

[*.json]
indent_size = 2

[*.yml]
indent_size = 2

[*.yaml]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.toml]
indent_size = 4

[{Makefile,*.mk}]
indent_style = tab
